// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Citizen {
  id            String   @id @default(uuid())
  phone         String   @unique
  name          String
  district      String?
  isVolunteer   Boolean  @default(false)
  volunteerWard String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tickets       Ticket[]
  claims        TicketClaim[]
}

model Department {
  id            String              @id @default(uuid())
  name          String              @unique
  slug          String?             @unique
  primaryDomain String?
  isCivicFacing Boolean             @default(true)
  employees     Employee[]
  tickets       Ticket[]
  categories    ComplaintCategory[]
}

model Jurisdiction {
  id        String     @id @default(uuid())
  level     String     // e.g., 'STATE', 'DISTRICT', 'TALUK', 'BLOCK', 'WARD', 'VILLAGE'
  name      String     // e.g., 'Chennai', 'Ward 12'
  parentId  String?    // Self-relation to build hierarchy
  parent    Jurisdiction?  @relation("Hierarchy", fields: [parentId], references: [id])
  children  Jurisdiction[] @relation("Hierarchy")
  track     String?    // URBAN, RURAL, REVENUE
  
  employees Employee[]
  tickets   Ticket[]
}

model Role {
  id                String   @id @default(uuid())
  code              String   @unique
  slug              String   @unique
  adminLevel        String
  jurisdictionScope String
  description       String
}

model ComplaintCategory {
  id                  String               @id @default(uuid())
  code                String               @unique
  name                String
  departmentId        String
  department          Department           @relation(fields: [departmentId], references: [id])
  defaultAssigneeRole String
  defaultPriority     String
  tickets             Ticket[]
  escalations         CategoryEscalation[]
}

model CategoryEscalation {
  id            String            @id @default(uuid())
  categoryId    String
  category      ComplaintCategory @relation(fields: [categoryId], references: [id])
  level         String            // L1, L2, L3, L4
  assigneeTitle String
  slaDays       Int
}

model TicketStateTransition {
  id          String @id @default(uuid())
  fromState   String
  toState     String
  performedBy String
  trigger     String
}

model Zone {
  id         String @id @default(uuid())
  zoneNumber String @unique
  name       String
  region     String
  wardFrom   Int
  wardTo     Int
}

model Employee {
  id             String        @id @default(uuid())
  username       String        @unique
  password       String
  phone          String?
  name           String
  category       String        // 'Elected Representative', 'Administrative Officer', 'Department Official'
  role           String        // e.g., 'District Collector', 'MLA', 'AE'
  
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id])
  
  jurisdictionId String?
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  assignedTickets Ticket[]     @relation("AssignedTo")
  ticketHistory   TicketHistory[]
}

model Ticket {
  id             String       @id @default(uuid())
  ticketNumber   String       @unique
  title          String
  description    String
  status         String       @default("SUBMITTED") // SUBMITTED, ASSIGNED, IN_PROGRESS, ESCALATED, RESOLVED, REOPENED, CLOSED
  priority       String       @default("MEDIUM")    // LOW, MEDIUM, HIGH, CRITICAL
  channel        String       @default("WEB")       // APP, WEB, HELPLINE, EMAIL, WALK_IN
  lat            Float?
  lng            Float?
  
  citizenId      String
  citizen        Citizen      @relation(fields: [citizenId], references: [id])
  
  departmentId   String?
  department     Department?  @relation(fields: [departmentId], references: [id])
  
  categoryId     String?
  category       ComplaintCategory? @relation(fields: [categoryId], references: [id])
  
  jurisdictionId String?
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  
  assignedToId   String?
  assignedTo     Employee?    @relation("AssignedTo", fields: [assignedToId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deadline       DateTime?

  photo          String?
  proofPhoto     String?
  rating         Int?
  reopenReason   String?

  history        TicketHistory[]
  claims         TicketClaim[]
  claimCount     Int          @default(0)
}

model TicketClaim {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  citizenId String
  citizen   Citizen  @relation(fields: [citizenId], references: [id])
  createdAt DateTime @default(now())

  @@unique([ticketId, citizenId])
}

model TicketHistory {
  id           String    @id @default(uuid())
  ticketId     String
  ticket       Ticket    @relation(fields: [ticketId], references: [id])
  
  action       String    // e.g., 'created', 'status_changed', 'assigned', 'commented'
  notes        String?
  
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id])
  
  createdAt    DateTime  @default(now())
}

